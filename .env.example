# =====================================================================
# PROPYTE CRM — Variables de entorno
# =====================================================================

# --- Base de datos ---
DATABASE_URL="postgresql://user:password@localhost:5432/propyte_crm"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# --- Twilio ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Sync Agents (Drive/Dropbox → CRM) ---

# Google Drive: path al JSON del service account
# 1. Crea un service account en Google Cloud Console
# 2. Habilita la Google Drive API
# 3. Descarga el JSON de credenciales
# 4. El desarrollador debe compartir la carpeta con el email del service account
GOOGLE_SERVICE_ACCOUNT_KEY="/path/to/service-account.json"

# Dropbox: tokens de la app
# 1. Crea una app en https://www.dropbox.com/developers/apps
# 2. Genera un access token
DROPBOX_ACCESS_TOKEN=""
DROPBOX_REFRESH_TOKEN=""
DROPBOX_CLIENT_ID=""
DROPBOX_CLIENT_SECRET=""

# Anthropic (Claude API para parsing de documentos)
ANTHROPIC_API_KEY=""

# Storage para imágenes procesadas (S3-compatible o Supabase Storage)
STORAGE_BUCKET="propyte-assets"
STORAGE_REGION="us-east-1"

# Cron secret para proteger el endpoint /api/sync/cron
CRON_SECRET="your-cron-secret-here"
