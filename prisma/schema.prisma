// =====================================================================
// PROPYTE CRM — Modelo de datos completo
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["propyte_crm"]
}

// =====================================================================
// ENUMS
// =====================================================================

// Roles de usuario para RBAC
enum UserRole {
  ADMIN
  ASESOR
  BROKER
  MANTENIMIENTO
  // Legacy roles (mantener por compatibilidad hasta migración completa)
  DIRECTOR
  GERENTE
  TEAM_LEADER
  ASESOR_SR
  ASESOR_JR
  HOSTESS
  MARKETING
  DEVELOPER_EXT

  @@schema("propyte_crm")
}

// Nivel en plan de carrera
enum CareerLevel {
  JR
  SR
  TOP_PRODUCER
  TEAM_LEADER
  GERENTE

  @@schema("propyte_crm")
}

// Plazas activas
enum Plaza {
  PDC
  TULUM
  MERIDA

  @@schema("propyte_crm")
}

// Tipo de contacto
enum ContactType {
  LEAD
  PROSPECTO
  CLIENTE
  INVERSIONISTA
  BROKER_EXTERNO
  REFERIDO

  @@schema("propyte_crm")
}

// Fuente del lead (crítico para atribución de marketing)
enum LeadSource {
  WALK_IN
  FACEBOOK_ADS
  GOOGLE_ADS
  INSTAGRAM
  PORTAL_INMOBILIARIO
  REFERIDO_CLIENTE
  REFERIDO_BROKER
  LLAMADA_FRIA
  EVENTO
  WEBSITE
  WHATSAPP
  OTRO

  @@schema("propyte_crm")
}

// Idioma preferido del contacto
enum PreferredLanguage {
  ES
  EN

  @@schema("propyte_crm")
}

// Perfil de inversión (del discovery call)
enum InvestmentProfile {
  END_USER
  INVESTOR_RENTAL
  INVESTOR_FLIP
  INVESTOR_LAND
  MIXED

  @@schema("propyte_crm")
}

// Tipo de propiedad buscada
enum PropertyType {
  DEPARTAMENTO
  CASA
  TERRENO
  MACROLOTE
  LOCAL_COMERCIAL
  OTRO

  @@schema("propyte_crm")
}

// Horizonte de compra
enum PurchaseTimeline {
  IMMEDIATE
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  SIX_PLUS_MONTHS

  @@schema("propyte_crm")
}

// Forma de pago
enum PaymentMethod {
  CONTADO
  CREDITO_HIPOTECARIO
  FINANCIAMIENTO_DIRECTO
  MIXTO

  @@schema("propyte_crm")
}

// Modalidad de compra preferida
enum PurchaseModality {
  PREVENTA
  ENTREGA_INMEDIATA
  REVENTA
  ABIERTO

  @@schema("propyte_crm")
}

// Estrategia de renta
enum RentalStrategy {
  LONG_TERM
  AIRBNB
  BOTH
  NA

  @@schema("propyte_crm")
}

// Temperatura del lead
enum LeadTemperature {
  HOT
  WARM
  COLD
  DEAD

  @@schema("propyte_crm")
}

// Tipo de desarrollo (relación comercial)
enum DevelopmentType {
  PROPIO
  MASTERBROKER
  CORRETAJE

  @@schema("propyte_crm")
}

// Moneda
enum Currency {
  MXN
  USD

  @@schema("propyte_crm")
}

// Estado del desarrollo
enum DevelopmentStatus {
  PREVENTA
  CONSTRUCCION
  ENTREGA_INMEDIATA
  VENDIDO
  SUSPENDIDO

  @@schema("propyte_crm")
}

// Tipo de unidad individual
enum UnitType {
  DEPTO_1REC
  DEPTO_2REC
  DEPTO_3REC
  PENTHOUSE
  CASA
  TERRENO
  MACROLOTE
  LOCAL

  @@schema("propyte_crm")
}

// Estado de la unidad
enum UnitStatus {
  DISPONIBLE
  APARTADA
  VENDIDA
  NO_DISPONIBLE

  @@schema("propyte_crm")
}

// Etapas del pipeline de ventas
enum DealStage {
  NEW_LEAD
  CONTACTED
  DISCOVERY_DONE
  MEETING_SCHEDULED
  MEETING_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  RESERVED
  CONTRACT_SIGNED
  CLOSING
  WON
  LOST
  FROZEN

  @@schema("propyte_crm")
}

// Tipo de operación (determina tabla de comisiones)
enum DealType {
  NATIVA_CONTADO
  NATIVA_FINANCIAMIENTO
  MACROLOTE
  CORRETAJE
  MASTERBROKER

  @@schema("propyte_crm")
}

// Razón de pérdida del deal
enum LostReason {
  PRECIO
  COMPETENCIA
  FINANCIAMIENTO_RECHAZADO
  NO_INTERESADO
  NO_CONTACTABLE
  COMPRO_DIRECTO
  DESARROLLO_CANCELADO
  OTRO

  @@schema("propyte_crm")
}

// Estado del pago de comisión
enum CommissionStatus {
  PENDIENTE
  FACTURADA
  PAGADA

  @@schema("propyte_crm")
}

// Tipo de actividad
enum ActivityType {
  CALL_OUTBOUND
  CALL_INBOUND
  WHATSAPP_OUT
  WHATSAPP_IN
  SMS_OUT
  SMS_IN
  EMAIL_SENT
  EMAIL_RECEIVED
  MEETING_VIRTUAL
  MEETING_PRESENTIAL
  MEETING_SHOWROOM
  DISCOVERY_CALL
  PROPOSAL_DELIVERY
  FOLLOW_UP
  WALK_IN
  NOTE
  TASK
  CONTRACT_REVIEW
  CLOSING_ACTIVITY

  @@schema("propyte_crm")
}

// Canal de mensaje (Twilio)
enum MessageChannel {
  WHATSAPP
  SMS

  @@schema("propyte_crm")
}

// Dirección del mensaje
enum MessageDirection {
  INBOUND
  OUTBOUND

  @@schema("propyte_crm")
}

// Estado del mensaje (Twilio)
enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED

  @@schema("propyte_crm")
}

// Estado de actividad
enum ActivityStatus {
  PENDIENTE
  COMPLETADA
  VENCIDA
  CANCELADA

  @@schema("propyte_crm")
}

// Propósito de visita (walk-in)
enum VisitPurpose {
  INVERSION
  USO_PROPIO
  INFORMACION
  OTRO

  @@schema("propyte_crm")
}

// Acción de auditoría
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT

  @@schema("propyte_crm")
}

// Categoría de fuente del lead (para reglas de comisión)
enum LeadSourceCategory {
  PROPYTE_LEAD
  BROKER_LEAD
  ASESOR_LEAD

  @@schema("propyte_crm")
}

// Modo de asignación de leads
enum LeadAssignmentMode {
  ROUND_ROBIN
  PERFORMANCE
  MANUAL
  GUARDIA

  @@schema("propyte_crm")
}

// =====================================================================
// MODELOS
// =====================================================================

// Usuarios del CRM
model User {
  id            String       @id @default(uuid())
  email         String       @unique
  name          String
  role          UserRole
  careerLevel   CareerLevel  @default(JR)
  plaza         Plaza
  teamLeaderId  String?
  teamLeader    User?        @relation("TeamMembers", fields: [teamLeaderId], references: [id])
  teamMembers   User[]       @relation("TeamMembers")
  sedetusNumber String?
  sedetusExpiry DateTime?
  isActive      Boolean      @default(true)
  avatarUrl     String?
  phone         String?
  passwordHash  String
  otpHash       String?
  otpExpiresAt  DateTime?

  // Relaciones
  assignedContacts  Contact[]    @relation("AssignedContacts")
  deals             Deal[]       @relation("AssignedDeals")
  activities        Activity[]
  walkInsAsHostess  WalkIn[]     @relation("HostessWalkIns")
  walkInsAsAdvisor  WalkIn[]     @relation("AdvisorWalkIns")
  reservedUnits     Unit[]       @relation("ReservedByUser")
  auditLogs         AuditLog[]
  notifications     Notification[]
  messages          Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
  @@schema("propyte_crm")
}

// Contactos / Leads
model Contact {
  id               String            @id @default(uuid())
  firstName        String
  lastName         String
  email            String?
  phone            String
  secondaryPhone   String?
  contactType      ContactType       @default(LEAD)
  leadSource       LeadSource
  leadSourceDetail String?
  residenceCity    String?
  residenceCountry String?
  nationality      String?
  preferredLanguage PreferredLanguage @default(ES)

  // Perfil de inversión (del discovery call)
  investmentProfile InvestmentProfile?
  propertyType      PropertyType?
  purchaseTimeline  PurchaseTimeline?
  budgetMin         Decimal?          @db.Decimal(14, 2)
  budgetMax         Decimal?          @db.Decimal(14, 2)
  paymentMethod     PaymentMethod?
  preferredZone     String?
  purchaseModality  PurchaseModality?
  rentalStrategy    RentalStrategy?

  // Asignación y scoring
  assignedToId String?
  assignedTo   User?            @relation("AssignedContacts", fields: [assignedToId], references: [id])
  temperature  LeadTemperature  @default(COLD)
  score        Int              @default(0)
  tags         String[]

  // Relaciones
  deals      Deal[]
  activities Activity[]
  walkIns    WalkIn[]
  units      Unit[]     @relation("ReservedByContact")
  messages   Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("contacts")
  @@schema("propyte_crm")
}

// Desarrollos inmobiliarios
model Development {
  id                   String            @id @default(uuid())
  name                 String
  developerName        String
  developmentType      DevelopmentType
  location             String
  plaza                Plaza
  totalUnits           Int
  availableUnits       Int
  soldUnits            Int               @default(0)
  reservedUnits        Int               @default(0)
  priceMin             Decimal           @db.Decimal(14, 2)
  priceMax             Decimal           @db.Decimal(14, 2)
  currency             Currency          @default(MXN)
  totalDevelopmentValue Decimal?         @db.Decimal(16, 2)
  commissionRate       Decimal           @db.Decimal(5, 2)
  status               DevelopmentStatus @default(PREVENTA)
  constructionProgress Int               @default(0)
  deliveryDate         DateTime?
  contractStartDate    DateTime?
  contractEndDate      DateTime?
  brochureUrl          String?
  virtualTourUrl       String?
  amenities            String[]
  description          String            @db.Text
  isActive             Boolean           @default(true)

  // Relaciones
  units Unit[]
  deals Deal[]
  monitoredFolders MonitoredFolder[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("developments")
  @@schema("propyte_crm")
}

// Unidades individuales de un desarrollo
model Unit {
  id            String     @id @default(uuid())
  developmentId String
  development   Development @relation(fields: [developmentId], references: [id])
  unitNumber    String
  unitType      UnitType
  area_m2       Decimal    @db.Decimal(10, 2)
  price         Decimal    @db.Decimal(14, 2)
  currency      Currency   @default(MXN)
  floor         Int?
  status        UnitStatus @default(DISPONIBLE)

  // Reservación
  reservedByContactId String?
  reservedByContact   Contact?  @relation("ReservedByContact", fields: [reservedByContactId], references: [id])
  reservedByUserId    String?
  reservedByUser      User?     @relation("ReservedByUser", fields: [reservedByUserId], references: [id])
  reservationDate     DateTime?
  saleDate            DateTime?
  salePrice           Decimal?  @db.Decimal(14, 2)

  // Relaciones
  deals Deal[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("units")
  @@schema("propyte_crm")
}

// Operaciones / Pipeline de ventas
model Deal {
  id              String    @id @default(uuid())
  contactId       String
  contact         Contact   @relation(fields: [contactId], references: [id])
  assignedToId    String
  assignedTo      User      @relation("AssignedDeals", fields: [assignedToId], references: [id])
  developmentId   String?
  development     Development? @relation(fields: [developmentId], references: [id])
  unitId          String?
  unit            Unit?     @relation(fields: [unitId], references: [id])

  // Pipeline
  stage           DealStage @default(NEW_LEAD)
  dealType        DealType
  estimatedValue  Decimal   @db.Decimal(14, 2)
  currency        Currency  @default(MXN)
  probability     Int       @default(5)
  expectedCloseDate DateTime
  actualCloseDate DateTime?

  // Pérdida
  lostReason       LostReason?
  lostReasonDetail String?

  // Comisiones calculadas
  commissionTotal    Decimal? @db.Decimal(14, 2)
  commissionAdvisor  Decimal? @db.Decimal(14, 2)
  commissionTL       Decimal? @db.Decimal(14, 2)
  commissionGerente  Decimal? @db.Decimal(14, 2)
  commissionDirector Decimal? @db.Decimal(14, 2)
  commissionBrokerExt Decimal? @db.Decimal(14, 2)
  commissionStatus   CommissionStatus @default(PENDIENTE)

  // Atribución
  leadSourceAtDeal String

  // Relaciones
  activities Activity[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("deals")
  @@schema("propyte_crm")
}

// Actividades e interacciones
model Activity {
  id              String         @id @default(uuid())
  contactId       String
  contact         Contact        @relation(fields: [contactId], references: [id])
  dealId          String?
  deal            Deal?          @relation(fields: [dealId], references: [id])
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  activityType    ActivityType
  subject         String
  description     String?        @db.Text
  dueDate         DateTime?
  completedAt     DateTime?
  status          ActivityStatus @default(PENDIENTE)
  outcome         String?
  duration_minutes Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("activities")
  @@schema("propyte_crm")
}

// Reglas de comisión configurables
model CommissionRule {
  id                 String             @id @default(uuid())
  dealType           DealType
  leadSourceCategory LeadSourceCategory
  role               UserRole
  percentage         Decimal            @db.Decimal(5, 2)
  isActive           Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commission_rules")
  @@schema("propyte_crm")
}

// Registro de walk-ins
model WalkIn {
  id                String       @id @default(uuid())
  hostessId         String
  hostess           User         @relation("HostessWalkIns", fields: [hostessId], references: [id])
  contactId         String
  contact           Contact      @relation(fields: [contactId], references: [id])
  arrivalTime       DateTime     @default(now())
  departureTime     DateTime?
  visitPurpose      VisitPurpose
  assignedAdvisorId String?
  assignedAdvisor   User?        @relation("AdvisorWalkIns", fields: [assignedAdvisorId], references: [id])
  convertedToDeal   Boolean      @default(false)
  notes             String?      @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("walk_ins")
  @@schema("propyte_crm")
}

// Registro de auditoría
model AuditLog {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@map("audit_logs")
  @@schema("propyte_crm")
}

// Notificaciones in-app
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // "lead_assigned", "task_overdue", "deal_stagnant", etc.
  isRead    Boolean  @default(false)
  link      String?  // URL de la entidad relacionada

  createdAt DateTime @default(now())

  @@map("notifications")
  @@schema("propyte_crm")
}

// Configuración global del sistema
model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value Json

  updatedAt DateTime @updatedAt

  @@map("system_config")
  @@schema("propyte_crm")
}

// Mensajes SMS/WhatsApp via Twilio
model Message {
  id            String           @id @default(uuid())
  contactId     String
  contact       Contact          @relation(fields: [contactId], references: [id])
  userId        String?
  user          User?            @relation(fields: [userId], references: [id])
  channel       MessageChannel
  direction     MessageDirection
  body          String           @db.Text
  mediaUrl      String?
  twilioSid     String?          @unique
  templateName  String?
  status        MessageStatus    @default(QUEUED)
  externalPhone String

  createdAt DateTime @default(now())

  @@index([contactId, createdAt])
  @@map("messages")
  @@schema("propyte_crm")
}

// Configuración de webhooks salientes (CRM → Zapier)
model WebhookConfig {
  id       String  @id @default(uuid())
  event    String  // "contact.created", "deal.won", etc.
  url      String
  isActive Boolean @default(true)
  secret   String  // HMAC signing secret

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhook_configs")
  @@schema("propyte_crm")
}

// =====================================================================
// SYNC AGENTS — Modelos para sincronización Drive/Dropbox → CRM
// =====================================================================

// Carpeta externa de Drive/Dropbox a la que el servicio da seguimiento
enum StorageProvider {
  GOOGLE_DRIVE
  DROPBOX

  @@schema("propyte_crm")
}

enum SyncJobStatus {
  PENDING
  CRAWLING
  PARSING
  MAPPING
  UPLOADING
  COMPLETED
  FAILED

  @@schema("propyte_crm")
}

// Carpetas monitoreadas (1 carpeta = 1 desarrollo)
model MonitoredFolder {
  id               String           @id @default(uuid())
  provider         StorageProvider
  externalFolderId String           // ID de la carpeta en Drive/Dropbox
  folderName       String
  folderUrl        String?          // URL compartida para acceso rápido
  developmentId    String?          // Desarrollo al que está vinculada (si ya existe)
  development      Development?     @relation(fields: [developmentId], references: [id])
  plaza            Plaza            @default(PDC)
  developmentType  DevelopmentType  @default(PROPIO)
  isActive         Boolean          @default(true)
  syncInterval     Int              @default(15) // minutos
  lastSyncAt       DateTime?
  lastSyncStatus   SyncJobStatus?

  // Relaciones
  syncJobs   SyncJob[]
  syncFiles  SyncFile[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([provider, externalFolderId])
  @@map("monitored_folders")
  @@schema("propyte_crm")
}

// Archivo individual rastreado dentro de una carpeta
model SyncFile {
  id                String          @id @default(uuid())
  monitoredFolderId String
  monitoredFolder   MonitoredFolder @relation(fields: [monitoredFolderId], references: [id])
  externalFileId    String          // ID del archivo en Drive/Dropbox
  fileName          String
  mimeType          String
  fileSize          Int             // bytes
  category          String          // PRICE_LIST, BROCHURE, RENDER, etc.
  externalModifiedAt DateTime       // Última modificación en Drive/Dropbox
  lastProcessedAt    DateTime?      // Última vez que se procesó
  checksum           String?        // Para detectar cambios reales
  processedData      Json?          // Datos extraídos del archivo (cache)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([monitoredFolderId, externalFileId])
  @@map("sync_files")
  @@schema("propyte_crm")
}

// Job de sincronización (un pipeline completo: crawl → parse → map → upload)
model SyncJob {
  id                String          @id @default(uuid())
  monitoredFolderId String
  monitoredFolder   MonitoredFolder @relation(fields: [monitoredFolderId], references: [id])
  status            SyncJobStatus   @default(PENDING)
  triggeredBy       String          // "CRON", "WEBHOOK", "MANUAL"
  developmentId     String?         // Desarrollo creado/actualizado

  // Métricas del job
  filesDiscovered   Int             @default(0)
  filesNew          Int             @default(0)
  filesModified     Int             @default(0)
  unitsCreated      Int             @default(0)
  unitsUpdated      Int             @default(0)
  imagesProcessed   Int             @default(0)

  // Estado detallado
  crawlData   Json?                // CrawlResult serializado
  parseData   Json?                // ParseResult serializado
  mapData     Json?                // MapResult serializado
  uploadData  Json?                // UploadResult serializado

  error       String?   @db.Text
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Logs del pipeline
  logs SyncLog[]

  createdAt DateTime @default(now())

  @@index([monitoredFolderId, createdAt])
  @@map("sync_jobs")
  @@schema("propyte_crm")
}

// Logs detallados de cada paso del pipeline
model SyncLog {
  id        String   @id @default(uuid())
  syncJobId String
  syncJob   SyncJob  @relation(fields: [syncJobId], references: [id])
  step      String   // "CRAWL", "PARSE", "MAP", "UPLOAD"
  level     String   // "INFO", "WARN", "ERROR"
  message   String   @db.Text
  data      Json?    // Datos adicionales

  createdAt DateTime @default(now())

  @@index([syncJobId, createdAt])
  @@map("sync_logs")
  @@schema("propyte_crm")
}

// =====================================================================
// META ADS — Cache de campañas e insights para dashboard
// =====================================================================

// Cuenta publicitaria de Meta monitoreada
model MetaAdAccount {
  id            String   @id @default(uuid())
  accountId     String   @unique // "act_803453467902414"
  name          String
  currency      String   @default("MXN")
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime?

  campaigns     MetaCampaignCache[]
  dailyInsights MetaDailyInsight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meta_ad_accounts")
  @@schema("propyte_crm")
}

// Cache de campañas con métricas snapshot
model MetaCampaignCache {
  id             String   @id @default(uuid())
  accountId      String
  account        MetaAdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metaCampaignId String
  name           String
  status         String   // ACTIVE, PAUSED, DELETED, etc.
  objective      String
  dailyBudget    Decimal? @db.Decimal(14, 2)
  lifetimeBudget Decimal? @db.Decimal(14, 2)
  startTime      DateTime?
  stopTime       DateTime?

  // Snapshot insights (período actual de sync)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  spend          Decimal  @default(0) @db.Decimal(14, 2)
  reach          Int      @default(0)
  cpc            Decimal? @db.Decimal(10, 4)
  ctr            Decimal? @db.Decimal(10, 4)
  cpm            Decimal? @db.Decimal(10, 4)
  leads          Int      @default(0)
  costPerLead    Decimal? @db.Decimal(14, 2)

  insightsPeriod String   @default("last_7d")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, metaCampaignId])
  @@map("meta_campaign_cache")
  @@schema("propyte_crm")
}

// Insights diarios por cuenta/campaña (histórico para charts)
model MetaDailyInsight {
  id             String   @id @default(uuid())
  accountId      String
  account        MetaAdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  level          String   // "account" o "campaign"
  metaObjectId   String   // account ID o campaign ID
  metaObjectName String?

  impressions    Int      @default(0)
  clicks         Int      @default(0)
  spend          Decimal  @default(0) @db.Decimal(14, 2)
  reach          Int      @default(0)
  cpc            Decimal? @db.Decimal(10, 4)
  ctr            Decimal? @db.Decimal(10, 4)
  cpm            Decimal? @db.Decimal(10, 4)
  frequency      Decimal? @db.Decimal(10, 4)
  leads          Int      @default(0)
  costPerLead    Decimal? @db.Decimal(14, 2)

  actionsJson    Json?

  createdAt DateTime @default(now())

  @@unique([accountId, date, level, metaObjectId])
  @@index([accountId, date])
  @@map("meta_daily_insights")
  @@schema("propyte_crm")
}

// =====================================================================
// META LEADS — Backup directo de leads de formularios Meta
// =====================================================================

enum MetaLeadStatus {
  PENDING           // Recién descargado, aún no comparado
  MATCHED           // Encontrado en CRM (Contact)
  MISSING_IN_CRM    // NO encontrado en CRM — discrepancia
  DUPLICATE         // Duplicado dentro de Meta

  @@schema("propyte_crm")
}

model MetaLead {
  id               String          @id @default(uuid())
  metaLeadId       String          @unique  // ID del lead en Meta (ej. "1234567890")
  createdOnMeta    DateTime                 // Fecha/hora en que se creó en Meta

  // Datos del formulario
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  country          String?
  language         String?          // "Espanol" | "Ingles"

  // Campos custom del formulario (urgencia, presupuesto, etc.)
  urgency          String?          // ¿Con qué urgencia quieres comprar?
  acquisition      String?          // ¿Cómo planeas adquirir tu propiedad?
  budget           String?          // Rango de presupuesto estimado
  description      String?          // Interés en inmueble
  extraFields      Json?            // Campos adicionales no mapeados

  // Atribución Meta
  campaignId       String?
  campaignName     String?
  adsetId          String?
  adsetName        String?
  adId             String?
  adName           String?
  formId           String?
  formName         String?
  platform         String?          // facebook, instagram, etc.
  pageName         String?

  // Matching con CRM
  status           MetaLeadStatus   @default(PENDING)
  matchedContactId String?          // UUID del Contact si se encontró match
  matchedAt        DateTime?
  matchMethod      String?          // "email", "phone", "both"

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([createdOnMeta])
  @@index([campaignName])
  @@map("meta_leads")
  @@schema("propyte_crm")
}

// API Keys para integraciones entrantes (Zapier → CRM)
model ApiKey {
  id         String   @id @default(uuid())
  name       String
  hashedKey  String   @unique
  prefix     String   // "pk_live_..." primeros 8 chars para identificación
  lastUsedAt DateTime?
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())

  @@map("api_keys")
  @@schema("propyte_crm")
}
